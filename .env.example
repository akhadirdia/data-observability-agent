# === LLM ===
# Obtenir sur https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# === Base de données surveillée ===
# SQLAlchemy URL — exemples :
#   SQLite  : sqlite:///./data.db
#   Postgres: postgresql://user:password@localhost:5432/mydb
#   BigQuery: bigquery://project/dataset
DATABASE_URL=sqlite:///./data.db

# === Notifications (optionnel) ===
# Slack : créer un Incoming Webhook sur https://api.slack.com/apps
SLACK_WEBHOOK_URL=

# Adresse email destinataire des alertes
ALERT_EMAIL=

# === Paramètres de l'agent ===
# "development" ou "production"
ENV=development

# Fréquence des vérifications automatiques en minutes
CHECK_INTERVAL_MINUTES=60
